# Petal web (Next.js) — multi-stage build for Railway.
# Built from the repo root: docker build -f Dockerfile.web .

# syntax=docker/dockerfile:1

FROM node:22-alpine AS base
ENV PNPM_HOME=/pnpm \
    PATH=/pnpm:$PATH \
    COREPACK_ENABLE_DOWNLOAD_PROMPT=0
# corepack picks the pnpm version pinned in package.json#packageManager
RUN corepack enable

# ---- fetch: warm the pnpm store from the lockfile alone, so dependency layers
# cache independently of source changes.
FROM base AS fetch
WORKDIR /repo
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm fetch

# ---- build: offline install across the workspace, then build apps/web.
FROM fetch AS build
WORKDIR /repo
COPY . .
RUN pnpm install --frozen-lockfile --offline
ENV NEXT_TELEMETRY_DISABLED=1
RUN pnpm --filter @petal/web build

# ---- run: standalone server only, as the non-root `node` user.
FROM node:22-alpine AS run
WORKDIR /app
ENV NODE_ENV=production \
    PORT=3000 \
    HOSTNAME=0.0.0.0 \
    NEXT_TELEMETRY_DISABLED=1
# `output: "standalone"` in a workspace emits the repo layout under .next/standalone,
# with the server entry at apps/web/server.js.
COPY --from=build --chown=node:node /repo/apps/web/.next/standalone ./
COPY --from=build --chown=node:node /repo/apps/web/.next/static ./apps/web/.next/static
COPY --from=build --chown=node:node /repo/apps/web/public ./apps/web/public
USER node
EXPOSE 3000
CMD ["node", "apps/web/server.js"]
